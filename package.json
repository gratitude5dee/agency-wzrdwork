{
  "name": "vite_react_shadcn_ts",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:watch": "node scripts/dev-runner.mjs watch",
    "dev:once": "node scripts/dev-runner.mjs dev",
    "dev:server": "pnpm --filter @paperclipai/server dev",
    "dev:ui": "pnpm --filter @paperclipai/ui dev",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "build:npm": "./scripts/build-npm.sh",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "pnpm --filter @paperclipai/db migrate",
    "db:migrate:canonical": "npm --workspace packages/db run migrate",
    "db:seed:canonical": "npm --workspace packages/db run seed",
    "db:backup": "./scripts/backup-db.sh",
    "cli:build": "npm --workspace cli run build",
    "cli:start": "npm run cli:build && node cli/dist/index.js",
    "paperclipai": "npm run cli:start --",
    "server:build": "npm --workspace server run build",
    "server:start": "npm run server:build && node server/dist/index.js",
    "control-plane:build": "npm --workspace control-plane run build",
    "control-plane:test": "npm run control-plane:build && node --test --experimental-strip-types control-plane/test/pure.test.ts control-plane/test/service.test.ts",
    "control-plane:start": "npm run control-plane:build && node control-plane/dist/index.js",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:run": "vitest run",
    "test:e2e": "npx playwright test --config tests/e2e/playwright.config.ts",
    "test:e2e:headed": "npx playwright test --config tests/e2e/playwright.config.ts --headed",
    "test:release-smoke": "npx playwright test --config tests/release-smoke/playwright.config.ts",
    "test:release-smoke:headed": "npx playwright test --config tests/release-smoke/playwright.config.ts --headed",
    "typecheck": "npm --workspaces --if-present run typecheck",
    "docs:dev": "cd docs && npx mintlify dev",
    "smoke:openclaw-join": "./scripts/smoke/openclaw-join.sh",
    "smoke:openclaw-docker-ui": "./scripts/smoke/openclaw-docker-ui.sh",
    "smoke:openclaw-sse-standalone": "./scripts/smoke/openclaw-sse-standalone.sh",
    "release": "./scripts/release.sh",
    "release:canary": "./scripts/release.sh canary",
    "release:stable": "./scripts/release.sh stable",
    "release:github": "./scripts/create-github-release.sh",
    "release:rollback": "./scripts/rollback-latest.sh",
    "check:tokens": "node scripts/check-forbidden-tokens.mjs",
    "secrets:migrate-inline-env": "tsx scripts/migrate-inline-env-secrets.ts"
  },
