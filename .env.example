# Supabase
VITE_SUPABASE_URL=https://lptryhnnhhvbblrrsaqa.supabase.co
VITE_SUPABASE_ANON_KEY=replace-with-your-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# Database
# Use the Supabase connection pooler URL for Vercel/serverless runtime.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-us-east-1.pooler.supabase.com:6543/postgres
# Use a direct connection URL for migrations when needed.
DATABASE_MIGRATION_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres
PAPERCLIP_DB_DISABLE_PREPARED_STATEMENTS=true
AGENCY_DB_DISABLE_PREPARED_STATEMENTS=true

# Public production URL and auth
PAPERCLIP_PUBLIC_URL=https://<production-domain>
BETTER_AUTH_SECRET=replace-with-random-long-secret
CRON_SECRET=replace-with-random-long-secret
PAPERCLIP_DEPLOYMENT_MODE=authenticated
PAPERCLIP_DEPLOYMENT_EXPOSURE=public
PAPERCLIP_ALLOWED_HOSTNAMES=<production-domain>

# Compatibility aliases used by the Vercel serverless entrypoint.
DEPLOYMENT_MODE=authenticated
DEPLOYMENT_EXPOSURE=public
ALLOWED_HOSTNAMES=<production-domain>

# Encryption keys must decode to 32 bytes: base64, 64-char hex, or raw 32-char string.
CONTROL_PLANE_ENCRYPTION_KEY=replace-with-32-byte-base64-or-hex-key
PAPERCLIP_SECRETS_MASTER_KEY=replace-with-32-byte-base64-or-hex-key

# Vercel Sandbox / control-plane defaults
CONTROL_PLANE_POLL_INTERVAL_MS=1500
CONTROL_PLANE_SCHEDULER_INTERVAL_MS=10000
CONTROL_PLANE_STALE_CLAIM_MS=300000
CONTROL_PLANE_MAX_ATTEMPTS=2
CONTROL_PLANE_ALLOWED_PROCESS_COMMANDS=node,bash,sh,python,python3
CONTROL_PLANE_ALLOWED_CODEX_COMMANDS=codex
CONTROL_PLANE_DEFAULT_CODEX_COMMAND=codex
SANDBOX_SNAPSHOT_ID=

# S3-compatible storage for documents/assets on Vercel.
PAPERCLIP_STORAGE_PROVIDER=s3
PAPERCLIP_STORAGE_S3_BUCKET=paperclip
PAPERCLIP_STORAGE_S3_REGION=us-east-1
PAPERCLIP_STORAGE_S3_ENDPOINT=
PAPERCLIP_STORAGE_S3_PREFIX=agency-wzrdwork
PAPERCLIP_STORAGE_S3_FORCE_PATH_STYLE=false
AWS_ACCESS_KEY_ID=replace-with-storage-access-key
AWS_SECRET_ACCESS_KEY=replace-with-storage-secret-key

# Local server defaults
PORT=3100
SERVE_UI=false
