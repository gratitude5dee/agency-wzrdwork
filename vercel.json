{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "framework": null,
  "buildCommand": "pnpm --filter @paperclipai/shared build && pnpm --filter @paperclipai/db build && pnpm --filter @paperclipai/adapter-utils build && pnpm --filter @paperclipai/plugin-sdk build && pnpm --filter @paperclipai/server compile && pnpm exec vite build",
  "outputDirectory": "dist",
  "installCommand": "pnpm install --no-frozen-lockfile --ignore-scripts",
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 60,
      "memory": 1024,
      "includeFiles": "{server/dist/**,packages/shared/dist/**,packages/db/dist/**,packages/adapter-utils/dist/**,packages/plugins/sdk/dist/**}",
      "excludeFiles": "{.vercel/**,.tmp-paperclip-adapter-loader-*/**,data/**,dist/**,ui/**,docs/**,**/*.test.ts,**/*.spec.ts,**/*.agency-backup.ts}"
    }
  },
  "rewrites": [
    { "source": "/api/cron/:path*", "destination": "/api/cron/$path*" },
    { "source": "/api/sandbox/spawn", "destination": "/api/sandbox/spawn" },
    { "source": "/api/sandbox/proxy/:path*", "destination": "/api/sandbox/proxy" },
    { "source": "/api/:path*", "destination": "/api/server" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/heartbeat-scheduler",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/heartbeat-worker",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/reap-orphans",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/sandbox-keepalive",
      "schedule": "*/5 * * * *"
    }
  ],
  "env": {
    "NODE_OPTIONS": "--max-old-space-size=512"
  }
}
